# ========================================================================
# Social Automation Agent - .gitignore
# Protects: Models, user data, secrets,downloads,venvs,etc.
# =======================================================================

# =======================================================================
# 1. VIRTUAL ENVIRONMENTS (ALL of them)
# =======================================================================
/venvs
/.venv
# =======================================================================
# 2. CONFIGS =======================================================================
*.env
*.env.local
.env
.env.*
!*.env.example
# =======================================================================
# 2. PYTHON
# =======================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
*.whl
.eggs/


